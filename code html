<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>PYchat par Gabriel LEGET</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
    :root {
        --bg-dark: #131314;
        --sidebar-bg: #1e1e1f;
        --chat-bg: #131314;
        --accent-orange: #ff7a00;
        --text-light: #e3e3e3;
        --user-msg: #2b2c2e;
        --bot-msg: #1e1e1f;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    body {
        background: var(--bg-dark);
        color: var(--text-light);
        display: flex;
        height: 100vh;
        overflow: hidden;
    }

    /* BARRE LATERALE */
    .sidebar {
        width: 260px;
        background: var(--sidebar-bg);
        display: flex;
        flex-direction: column;
        padding: 15px;
        border-right: 1px solid #2d2d2e;
        z-index: 10;
    }

    .sidebar h2 {
        color: var(--accent-orange);
        font-size: 22px;
        margin-bottom: 20px;
        text-align: center;
    }

    .btn {
        background: #2b2c2e;
        color: white;
        border: 1px solid #444;
        padding: 10px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn:hover {
        background: #3e3f42;
    }

    .convList {
        flex: 1;
        overflow-y: auto;
        margin-top: 10px;
    }

    .convItem {
        padding: 10px;
        margin-bottom: 5px;
        background: transparent;
        border-radius: 6px;
        cursor: pointer;
        font-size: 14px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: background 0.2s;
    }

    .convItem:hover, .convItem.active {
        background: #2d2d2e;
        color: var(--accent-orange);
    }

    /* ZONE PRINCIPALE */
    .main {
        flex: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
        background: var(--chat-bg);
    }

    .header {
        height: 60px;
        background: var(--sidebar-bg);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        border-bottom: 1px solid #2d2d2e;
    }

    .title-container .title {
        font-weight: 600;
        font-size: 16px;
    }

    .title-container .status-indicator {
        font-size: 11px;
        color: #888;
    }

    .actions button {
        background: transparent;
        border: none;
        color: #aaa;
        font-size: 16px;
        margin-left: 10px;
        cursor: pointer;
        padding: 5px;
        border-radius: 4px;
    }

    .actions button:hover {
        color: white;
        background: #2d2d2e;
    }

    /* MESSAGES */
    .chatArea {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .message {
        max-width: 80%;
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 15px;
        line-height: 1.5;
        word-wrap: break-word;
    }

    .message.user {
        background: var(--user-msg);
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }

    .message.bot {
        background: var(--bot-msg);
        align-self: flex-start;
        border-bottom-left-radius: 2px;
        border: 1px solid #2d2d2e;
    }

    .message img {
        display: block;
        max-width: 100%;
        max-height: 250px;
        border-radius: 8px;
        margin-top: 10px;
    }

    /* ZONE ENTRÉE */
    .inputArea {
        padding: 20px;
        display: flex;
        gap: 10px;
        background: var(--chat-bg);
    }

    .inputArea input[type="text"] {
        flex: 1;
        background: #202123;
        border: 1px solid #3c3d3f;
        color: white;
        padding: 12px;
        border-radius: 8px;
        outline: none;
    }

    .inputArea button {
        background: var(--accent-orange);
        color: white;
        border: none;
        padding: 0 20px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
    }

    .inputArea button:hover {
        opacity: 0.9;
    }

    #btnImage {
        background: #2b2c2e;
        border: 1px solid #444;
        font-size: 18px;
    }

    /* PANNEAU PARAMÈTRES */
    .settingsPanel {
        position: fixed;
        right: -300px;
        top: 60px;
        width: 300px;
        height: calc(100vh - 60px);
        background: var(--sidebar-bg);
        border-left: 1px solid #2d2d2e;
        transition: right 0.3s ease;
        padding: 20px;
        z-index: 5;
    }

    .settingsPanel.active {
        right: 0;
    }

    .settingsPanel h3 {
        margin-bottom: 20px;
        color: var(--accent-orange);
    }

    .setting {
        margin-bottom: 15px;
        font-size: 14px;
    }

    .setting label {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .setting input, .setting select {
        background: #2b2c2e;
        border: 1px solid #444;
        color: white;
        padding: 4px;
        border-radius: 4px;
    }

    /* ANIMATION POINTS DE FRAPPE (TYPING DOTS) */
    .typing-dots {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        margin-left: 5px;
    }

    .typing-dots span {
        width: 6px;
        height: 6px;
        background: var(--accent-orange);
        border-radius: 50%;
        animation: blink 10.4s infinite both;
    }

    .typing-dots span:nth-child(2) { animation-delay: .4s; }
    .typing-dots span:nth-child(3) { animation-delay: .8s; }

    @keyframes blink {
        0% { opacity: .2; }
        20% { opacity: 1; }
        100% { opacity: .2; }
    }
</style>
</head>
