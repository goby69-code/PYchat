    const conv = data.convs.find(c=>c.id===currentConvId);
    if(conv) {
        const name = prompt("Nouveau nom :", conv.title);
        if(name) { conv.title=name.trim(); conv.modified=new Date().toISOString(); renderConvList(); renderConversation(); saveData(); }
    }
};

document.getElementById('btnDuplicate').onclick = () => {
    const conv = data.convs.find(c=>c.id===currentConvId);
    if(conv) {
        const copy = JSON.parse(JSON.stringify(conv));
        copy.id = Date.now().toString(36);
        copy.title = conv.title+" (copie)";
        copy.created = new Date().toISOString();
        copy.modified = copy.created;
        data.convs.unshift(copy);
        if(data.convs.length > data.settings.limit) data.convs.pop();
        renderConvList(); saveData();
    }
};

document.getElementById('btnDelete').onclick = () => {
    if(confirm("Supprimer cette discussion définitivement ?")) {
        data.convs = data.convs.filter(c=>c.id!==currentConvId);
        if(data.convs.length === 0) createConversation();
        else currentConvId = data.convs[0].id;
        renderConvList(); renderConversation(); saveData();
    }
};

function renderConvList() {
    const list = document.getElementById('convList'); list.innerHTML='';
    data.convs.forEach(c => {
        const div = document.createElement('div');
        div.className = 'convItem'+(c.id===currentConvId?' active':'');
        div.innerText = c.title + " ("+c.items.length+")";
        div.onclick = () => { currentConvId = c.id; renderConvList(); renderConversation(); };
        list.appendChild(div);
    });
}

function renderConversation() {
    const conv = data.convs.find(c=>c.id===currentConvId);
    const area = document.getElementById('chatArea'); area.innerHTML='';
    if(!conv) return;
    document.getElementById('chatTitle').innerText = conv.title;
    conv.items.forEach(item => {
        const div = document.createElement('div');
        div.className = 'message ' + (item.sender === 'user' ? 'user' : 'bot');
        div.innerText = item.text;
        if(item.image) {
            const img = document.createElement('img');
            img.src = item.image;
            div.appendChild(img);
        }
        area.appendChild(div);
    });
    area.scrollTop = area.scrollHeight;
}

function addChatMessage(sender, text, imageData=null, dynamicTyping=false) {
    const area = document.getElementById('chatArea');
    const div = document.createElement('div');
    div.className = 'message ' + (sender === 'user' ? 'user' : 'bot');
    
    if (dynamicTyping) {
        const words = text.split(' ');
        let currentWordIndex = 0;
        div.innerText = "";
        
        const interval = setInterval(() => {
            if (currentWordIndex < words.length) {
                div.innerText += (currentWordIndex === 0 ? "" : " ") + words[currentWordIndex];
                currentWordIndex++;
                area.scrollTop = area.scrollHeight;
            } else {
                clearInterval(interval);
                if(imageData) {
                    const img = document.createElement('img');
                    img.src = imageData;
                    div.appendChild(img);
                }
                area.scrollTop = area.scrollHeight;
            }
        }, 60); 
    } else {
        div.innerText = text;
        if(imageData) {
            const img = document.createElement('img');
            img.src = imageData;
            div.appendChild(img);
        }
    }

    area.appendChild(div);
    area.scrollTop = area.scrollHeight;
    
    const conv = data.convs.find(c=>c.id===currentConvId);
    if(conv) {
        conv.items.push({sender:sender, text:text, image:imageData});
        conv.modified = new Date().toISOString();
        saveData();
    }
}

document.getElementById('btnSend').onclick = handleSend;
document.getElementById('userInput').addEventListener('keypress', function(e){ if(e.key==='Enter') handleSend(); });

function handleSend() {
    const input = document.getElementById('userInput');
    let text = input.value.trim();
    if(!text) return;

    addChatMessage('user', text, null, false);
    input.value = "";
    
    const lower = text.toLowerCase();

    const area = document.getElementById('chatArea');
    const typingIndicator = document.createElement('div');
    typingIndicator.className = 'message bot';
    typingIndicator.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
    
    area.appendChild(typingIndicator);
    area.scrollTop = area.scrollHeight;

    if(lower.startsWith("génère") || lower.startsWith("genere")) {
        updateStatusText('Calcul Image...');
        setTimeout(() => {
            typingIndicator.remove();
            const imgData = generateImage(text);
            addChatMessage('bot', 'Image générée avec succès 🎨', imgData, true);
            updateStatusText('IA Locale Prête ✓');
        }, 1200); 
        return; 
    }

    if (lower.includes("heure")) {
        setTimeout(() => {
            typingIndicator.remove();
            addChatMessage('bot', "Il est actuellement " + (new Date()).toLocaleTimeString() + ".", null, true);
            updateStatusText('IA Locale Prête ✓');
        }, 800);
        return;
    }
    if (lower.includes("date") || lower.includes("jour")) {
        setTimeout(() => {
            typingIndicator.remove();
            addChatMessage('bot', "Nous sommes le " + (new Date()).toLocaleDateString() + ".", null, true);
            updateStatusText('IA Locale Prête ✓');
        }, 800);
        return;
    }

    updateStatusText('Calcul...');
    
    setTimeout(() => {
        typingIndicator.remove();
        const context = pyChatAI.detectContext(text);
        pyChatAI.dynamicTrain(text, context);
        
        const response = pyChatAI.generateResponse(text);
        addChatMessage('bot', response, null, true);
        
        updateStatusText('IA Locale Prête ✓');
    }, 1000); 
}

document.getElementById('imageInput').onchange = function(e) {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
        const dataUrl = ev.target.result;
        addChatMessage('user', '[Image transférée]', dataUrl, false);
        addChatMessage('bot', 'Image reçue localement dans la session.', null, true);
    };
    reader.readAsDataURL(file);
};
document.getElementById('btnImage').onclick = () => { document.getElementById('imageInput').click(); };

document.getElementById('btnExport').onclick = () => {
    const blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'pychat_dynamic_data.json';
    a.click();
};
document.getElementById('btnImport').onclick = () => { document.getElementById('fileImport').click(); };
document.getElementById('fileImport').onchange = function(e) {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
        try {
            const obj = JSON.parse(ev.target.result);
            if(obj.convs) {
                data = obj;
                loadData();
            }
        } catch { alert("Fichier JSON corrompu ou invalide"); }
    };
    reader.readAsText(file);
};

document.getElementById('btnSettingsToggle').onclick = function() {
    document.getElementById('settingsPanel').classList.toggle('active');
};
document.getElementById('chkAutoSave').onchange = function(e) { data.settings.autoSave = e.target.checked; };
document.getElementById('numLimit').onchange = function(e) { data.settings.limit = parseInt(e.target.value); };
document.getElementById('chkCompress').onchange = function(e) { data.settings.compress = e.target.checked; };

window.onload = function() {
    simulateLoading(loadData);
};
</script>
