// ============================================
// MOTEUR D'IA CONTEXTUELLE CHROME-MARKOV
// ============================================
class ContextualMarkov {
    constructor() {
        this.brains = {}; 
        this.keywords = {
            salutation: ['salut', 'bonjour', 'coucou', 'hello', 'hey', 'salutations', 'bonsoir', 'bienvenue'],
            identite: ['nom', 'appelles', 'appel', 'qui es', 'tu es', 'qui es tu'],
            ia: ['ia', 'intelligence', 'artificielle', 'robot', 'machine', 'code'],
            humeur: ['va', 'vas', 'ça va', 'forme', 'comment']
        };
    }

    tokenize(text) {
        if (!text) return [];
        return text.toLowerCase()
            .replace(/[^\w\s']/gi, '')
            .split(/\s+/)
            .filter(t => t.length > 0);
    }

    trainAll() {
        this.brains = {}; 
        trainingData.forEach(item => {
            if (!this.brains[item.context]) {
                this.brains[item.context] = { chain: {}, starts: [] };
            }
            
            const tokens = this.tokenize(item.text);
            if (tokens.length === 0) return;

            this.brains[item.context].starts.push(tokens[0]);

            for (let i = 0; i < tokens.length - 1; i++) {
                const current = tokens[i];
                const next = tokens[i + 1];
                
                if (!this.brains[item.context].chain[current]) {
                    this.brains[item.context].chain[current] = [];
                }
                this.brains[item.context].chain[current].push(next);
            }
        });
    }

    dynamicTrain(userInput, context = 'inconnu') {
        if(!this.brains[context]) {
            this.brains[context] = { chain: {}, starts: [] };
        }
        const tokens = this.tokenize(userInput);
        if(tokens.length === 0) return;
        
        this.brains[context].starts.push(tokens[0]);
        for (let i = 0; i < tokens.length - 1; i++) {
            const current = tokens[i];
            const next = tokens[i + 1];
            if (!this.brains[context].chain[current]) {
                this.brains[context].chain[current] = [];
            }
            this.brains[context].chain[current].push(next);
        }
    }

    detectContext(userInput) {
        const cleanInput = userInput.toLowerCase();
        let scores = { salutation: 0, identite: 0, ia: 0, humeur: 0 };
        let maxScore = 0;
        let detectedContext = 'inconnu';

        for (let context in this.keywords) {
            this.keywords[context].forEach(keyword => {
                if (cleanInput.includes(keyword)) {
                    scores[context] += 1;
                }
            });
            if (scores[context] > maxScore) {
                maxScore = scores[context];
                detectedContext = context;
            }
        }
        return detectedContext;
    }

    generateResponse(userInput) {
        const context = this.detectContext(userInput);
        const brain = this.brains[context] || this.brains['inconnu'];
        
        if (!brain || !brain.starts || brain.starts.length === 0) {
            return "Mes circuits rechargent leurs batteries.";
        }

        let finalSentence = "";
        let attempts = 0;

        while (attempts < 10) {
            let currentWord = brain.starts[Math.floor(Math.random() * brain.starts.length)];
            let result = [currentWord];

            for (let i = 0; i < 15; i++) {
                const nextOptions = brain.chain[currentWord];
                if (!nextOptions || nextOptions.length === 0) break;
                
                const nextWord = nextOptions[Math.floor(Math.random() * nextOptions.length)];
                if (!nextWord) break;
                
                result.push(nextWord);
                currentWord = nextWord;
            }

            finalSentence = result.join(' ').trim();
            finalSentence = finalSentence.charAt(0).toUpperCase() + finalSentence.slice(1) + ".";

            if (!recentResponses.includes(finalSentence)) {
                break;
            }
            attempts++;
        }

        recentResponses.push(finalSentence);
        if (recentResponses.length > 4) recentResponses.shift();

        return finalSentence;
    }
}

const pyChatAI = new ContextualMarkov();

// Simulation animée du faux écran d'initialisation
function simulateLoading(callback) {
    let percent = 0;
    const bar = document.getElementById('loadingBar');
    const txt = document.getElementById('loadingPercent');
    const screen = document.getElementById('loadingScreen');
    
    const interval = setInterval(() => {
        percent += Math.floor(Math.random() * 15) + 5;
        if(percent >= 100) {
            percent = 100;
            clearInterval(interval);
            bar.style.width = '100%';
            txt.textContent = '100%';
            setTimeout(() => {
                screen.style.opacity = '0';
                setTimeout(() => screen.remove(), 500);
                callback();
            }, 400);
        } else {
            bar.style.width = percent + '%';
            txt.textContent = percent + '%';
        }
    }, 80);
}

function loadData() {
    const s = localStorage.getItem('pychat_data');
    if(s) {
        try { data = JSON.parse(s); } catch(e){ console.warn("JSON parse error:", e); }
    }
    if(!data.convs) data.convs = [];
    if(data.convs.length === 0) {
        createConversation();
    } else {
        currentConvId = data.convs[0].id;
    }
    
    pyChatAI.trainAll();
    updateStatusText('IA Locale Prête ✓');
    renderConvList(); 
    renderConversation();
}

function saveData() {
    if(data.settings.autoSave) {
        localStorage.setItem('pychat_data', JSON.stringify(data));
    }
}

function updateStatusText(text) {
    document.getElementById('modelStatus').textContent = text;
}

function generateImage(prompt) {
    const style = document.getElementById('selStyle').value;
    const size = parseInt(document.getElementById('selSize').value);
    const canvas = document.createElement('canvas');
    canvas.width = size; canvas.height = size;
    const ctx = canvas.getContext('2d');
    let grad;
    let mode = style;
    const p = prompt.toLowerCase();
    
    if(mode === 'auto') {
        if(p.includes('feu')) mode = 'feu';
        else if(p.includes('glace')) mode = 'glace';
        else if(p.includes('galaxie')) mode = 'galaxie';
        else mode = 'abstrait';
    }
    
    if(mode === 'feu') {
        grad = ctx.createLinearGradient(0,0,size,size);
        grad.addColorStop(0,'#ff2a00'); grad.addColorStop(0.5, '#ff7a00'); grad.addColorStop(1,'#ffcc00');
    } else if(mode === 'glace') {
        grad = ctx.createLinearGradient(0,0,size,size);
        grad.addColorStop(0,'#0055ff'); grad.addColorStop(0.5, '#00aeff'); grad.addColorStop(1,'#a0eaff');
    } else if(mode === 'galaxie') {
        grad = ctx.createRadialGradient(size/2,size/2,size*0.05,size/2,size/2,size*0.9);
        grad.addColorStop(0,'#8a2be2'); grad.addColorStop(0.3, '#4b0082'); grad.addColorStop(1,'#050510');
    } else {
        grad = ctx.createLinearGradient(0,0,size,size);
        grad.addColorStop(0,'#2c3e50'); grad.addColorStop(1,'#3498db');
    }
    
    ctx.fillStyle = grad; 
    ctx.fillRect(0,0,size,size);
    
    for(let i=0; i<80; i++){
        ctx.beginPath();
        const x = Math.random()*size, y = Math.random()*size;
        const r = Math.random()*(size*0.05) + 2;
        ctx.arc(x,y,r,0,Math.PI*2);
        
        if(mode === 'feu') {
            ctx.fillStyle = `rgba(255, ${Math.floor(Math.random()*150 + 100)}, 0, ${Math.random()*0.4})`;
        } else if(mode === 'glace') {
            ctx.fillStyle = `rgba(180, 240, 255, ${Math.random()*0.5})`;
        } else if(mode === 'galaxie') {
            ctx.fillStyle = `rgba(${Math.floor(Math.random()*100 + 155)}, 255, 255, ${Math.random()*0.6})`;
        } else {
            ctx.fillStyle = `rgba(255,255,255,${Math.random()*0.3})`;
        }
        ctx.fill();
    }
    
    return canvas.toDataURL("image/png");
}

function createConversation(title="Nouvelle discussion") {
    const id = Date.now().toString(36), now = new Date().toISOString();
    data.convs.unshift({id:id, title:title, created:now, modified:now, items:[]});
    if(data.convs.length > data.settings.limit) data.convs.pop();
    currentConvId = id;
    renderConvList(); renderConversation(); saveData();
}

document.getElementById('newConvBtn').onclick = () => {
    const name = prompt("Titre de la discussion :", "Nouvelle discussion");
    if(name) createConversation(name.trim());
};

